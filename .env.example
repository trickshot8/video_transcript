# ====== 复制本文件为 .env 并按需填写 ======

# B站登录 Cookie（强烈建议填写）。
# 现在 B站字幕列表接口基本都需要登录态才能返回 CC / AI 字幕。
# 获取方法：浏览器登录 bilibili.com -> F12 -> Application -> Cookies -> 复制 SESSDATA 的值。
BILIBILI_SESSDATA=

# 服务监听地址与端口。0.0.0.0 让局域网/Tailscale 内其他设备(手机)可访问。
HOST=0.0.0.0
PORT=8765

# 简单的访问令牌。iOS 快捷指令请求时带上 ?token=xxx，防止别人乱调。留空则不校验。
API_TOKEN=

# markdown 字幕输出目录（绝对路径或相对本项目）。
OUTPUT_DIR=output

# 是否启用本地 Whisper 兜底（B站无CC/AI字幕时）。
# 树莓派等弱算力设备建议设 false：B站AI字幕覆盖约75%，无字幕的多是游戏/音乐/鬼畜类，
# 关掉可省去 faster-whisper 重依赖，无字幕时直接回执提示。
ENABLE_WHISPER=true

# faster-whisper 模型大小: tiny / base / small / medium / large-v3
# 中文推荐 small 或 medium。越大越准也越慢。
WHISPER_MODEL=small

# 计算设备: cpu 或 cuda（有 NVIDIA 显卡且装了 CUDA 时用 cuda 会快很多）
WHISPER_DEVICE=cpu

# 计算精度: cpu 用 int8；cuda 可用 float16
WHISPER_COMPUTE_TYPE=int8
