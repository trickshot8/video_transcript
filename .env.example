# ====== 复制本文件为 .env 并按需填写 ======

# B站登录 Cookie（强烈建议填写）。
# 现在 B站字幕列表接口基本都需要登录态才能返回 CC / AI 字幕。
# 获取方法：浏览器登录 bilibili.com -> F12 -> Application -> Cookies -> 复制 SESSDATA 的值。
BILIBILI_SESSDATA=

# 服务监听地址与端口。0.0.0.0 让局域网/Tailscale 内其他设备(手机)可访问。
HOST=0.0.0.0
PORT=8765

# 简单的访问令牌。iOS 快捷指令请求时带上 ?token=xxx，防止别人乱调。留空则不校验。
API_TOKEN=

# ===== 输出目录（按部署方式二选一）=====
#
# 【直接跑 python server.py（如 PC）】用 OUTPUT_DIR 指定写哪：
OUTPUT_DIR=output
#
# 【Docker 部署（树莓派）】OUTPUT_DIR 会被 docker-compose 强制成容器内的
# /data/subtitles，上面这行不用管；真正要设的是下面这个【宿主机】路径，
# docker-compose 会把它 bind-mount 进容器。**不设的话会默认写到 ./output（坑）**：
OUTPUT_HOST_DIR=/DATA/Documents/b站视频字幕

# ===== 字幕总结（服务端 LLM，默认 DeepSeek）=====
# 开关；不想要摘要设 false。
SUMMARY_ENABLED=true
# DeepSeek API Key（https://platform.deepseek.com 申请）。留空则跳过摘要、只出字幕。
DEEPSEEK_API_KEY=
# 兼容其它 OpenAI 风格接口时改这两个（默认 DeepSeek）
SUMMARY_BASE_URL=https://api.deepseek.com
SUMMARY_MODEL=deepseek-chat

# 是否启用本地 Whisper 兜底（B站无CC/AI字幕时）。
# 树莓派等弱算力设备建议设 false：B站AI字幕覆盖约75%，无字幕的多是游戏/音乐/鬼畜类，
# 关掉可省去 faster-whisper 重依赖，无字幕时直接回执提示。
ENABLE_WHISPER=true

# faster-whisper 模型大小: tiny / base / small / medium / large-v3
# 中文推荐 small 或 medium。越大越准也越慢。
WHISPER_MODEL=small

# 计算设备: cpu 或 cuda（有 NVIDIA 显卡且装了 CUDA 时用 cuda 会快很多）
WHISPER_DEVICE=cpu

# 计算精度: cpu 用 int8；cuda 可用 float16
WHISPER_COMPUTE_TYPE=int8
