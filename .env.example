# ====== 复制本文件为 .env 并按需填写 ======

# B站登录 Cookie（强烈建议填写）。
# 现在 B站字幕列表接口基本都需要登录态才能返回 CC / AI 字幕。
# 获取方法：浏览器登录 bilibili.com -> F12 -> Application -> Cookies -> 复制 SESSDATA 的值。
BILIBILI_SESSDATA=

# YouTube cookies 文件路径(Netscape 格式)，可选。YouTube 对字幕下载限流较狠，
# 提供登录态 cookies 能大幅缓解 429。导出方法见 README。留空则不带。
YOUTUBE_COOKIES=

# 服务监听地址与端口。0.0.0.0 让局域网/Tailscale 内其他设备(手机)可访问。
HOST=0.0.0.0
PORT=8765

# 简单的访问令牌。iOS 快捷指令请求时带上 ?token=xxx，防止别人乱调。留空则不校验。
API_TOKEN=

# ===== 输出目录（按部署方式二选一）=====
# 【直接跑 python server.py（如 PC）】用 OUTPUT_DIR 指定写哪：
OUTPUT_DIR=output
# 【Docker 部署（树莓派）】容器内固定写 /data/subtitles，宿主机目录在 docker-compose 里挂载。
OUTPUT_HOST_DIR=/DATA/Documents/b站视频字幕

# ===== 字幕总结（服务端 LLM，默认 DeepSeek）=====
SUMMARY_ENABLED=true
DEEPSEEK_API_KEY=
SUMMARY_BASE_URL=https://api.deepseek.com
SUMMARY_MODEL=deepseek-chat

# 可选：写入 catalog 性能记录，方便不同硬件/API 横向比较。
PERF_HOST_LABEL=pi5

# ===== 本地 Whisper 兜底 =====
# 树莓派等弱算力设备建议设 false。
ENABLE_WHISPER=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ===== 云 ASR 兜底（无平台字幕时，默认 SenseVoiceSmall API）=====
# 开关。想只用平台字幕 + 本地 Whisper 时可设 false。
ASR_ENABLED=true
# 硅基流动 API Key。留空则自动跳过云端 ASR fallback。
ASR_API_KEY=
# OpenAI 兼容地址。默认是硅基流动。
ASR_BASE_URL=https://api.siliconflow.cn/v1
# 默认模型：SenseVoiceSmall
ASR_MODEL=FunAudioLLM/SenseVoiceSmall
